{
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": "^8.1",
    "ext-ctype": "*",
    "ext-iconv": "*",
    "symfony/console": "^6.0",
    "symfony/dotenv": "^6.0",
    "symfony/flex": "^2",
    "symfony/framework-bundle": "^6.0",
    "symfony/yaml": "^6.0",
    "symfony/maker-bundle": "^1.0",
    "symfony/validator": "6.4.*",
    "nelmio/cors-bundle": "*",
    "doctrine/doctrine-bundle": "^2.11",
    "doctrine/doctrine-migrations-bundle": "^3.3",
    "doctrine/orm": "^2.17"
  },
  "require-dev": {
    "symfony/debug-bundle": "^6.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "scripts": {},
  "config": {
    "allow-plugins": {
      "symfony/flex": true
    },
    "platform": {
      "php": "8.3.16"
    }
  },
  "extra": {
    "symfony": {
      "allow-contrib": false,
      "require": "6.4.*"
    }
  }
}
